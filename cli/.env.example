FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Firebase Client SDK config ─────────────────────────────────────────────
# Lấy tại: Firebase Console → Project Settings → General → Your apps → Web app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

BUILDS_COLLECTION=builds


# ── Apple Developer credentials (optional — CLI sẽ prompt nếu không có) ───
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# ── App info ───────────────────────────────────────────────────────────────
BUNDLE_ID=com.yourcompany.yourapp
TEAM_ID=XXXXXXXXXX
SCHEME_NAME=YourApp
XCWORKSPACE=YourApp.xcworkspace
XCODEPROJ=YourApp.xcodeproj

# Absolute path to the iOS project root (defaults to cwd)
# PROJECT_ROOT=/path/to/your/project
